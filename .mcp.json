{
  "mcpServers": {
    "kryonix-brain": {
      "command": "/run/current-system/sw/bin/uv",
      "args": [
        "--quiet",
        "run",
        "--project",
        "/etc/kryonix/packages/kryonix-brain-lightrag",
        "kg-server"
      ],
      "cwd": "/etc/kryonix"
    },
    "mcp-nixos": {
      "command": "/run/current-system/sw/bin/uv",
      "args": [
        "tool",
        "run",
        "mcp-nixos",
        "--stdio"
      ]
    },
    "vault-readonly": {
      "command": "/run/current-system/sw/bin/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/etc/kryonix",
        "/home/rocha/.local/share/kryonix/kryonix-vault",
        "/var/lib/kryonix"
      ]
    },
    "github": {
      "command": "/run/current-system/sw/bin/npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github",
        "--stdio"
      ]
    }
  }
}

#!/usr/bin/env bash

# =============================================================================
# Autor: rag
#
# O que é:
# - Helper para selecionar um projeto e abrir um terminal já no diretório escolhido.
#
# Por quê:
# - Acelera navegação entre repositórios sem precisar digitar caminhos.
#
# Como:
# - Lista diretórios em `~/Documents/repositories` e usa `fzf` para seleção.
# - Abre o `kryonix-terminal` (Tilix) e inicia `zellij` no diretório selecionado.
#
# Riscos:
# - Depende de `fzf`, `kryonix-terminal` e `zellij` estarem disponíveis no PATH.
# - Se o diretório base mudar, a busca não encontra projetos.
# =============================================================================

selected=$(find ~/Documents/repositories -mindepth 1 -maxdepth 2 -type d -not -iwholename '*.git*' | fzf)
if [ -n "$selected" ]; then
	# Abre o Tilix via launcher do repo já no diretório selecionado
	kryonix-terminal start --cwd "$selected" -- zellij || exit
fi

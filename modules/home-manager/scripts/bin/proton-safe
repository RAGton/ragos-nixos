#!/usr/bin/env bash

# =============================================================================
# Autor: rag
#
# O que é:
# - Wrapper genérico para executar um comando “desligando” Wayland/HDR no Proton/DXVK.
#
# Por quê:
# - Útil para contornar crashes/regressões em alguns setups (ex.: NVIDIA + HDR/Wayland).
#
# Como:
# - Exporta `PROTON_ENABLE_WAYLAND=0`, `PROTON_ENABLE_HDR=0` e `DXVK_HDR=0`.
# - Executa o comando recebido via `exec "$@"`.
#
# Riscos:
# - Pode desabilitar recursos que você gostaria de usar em máquinas compatíveis.
# =============================================================================

# Força desligar Wayland + HDR no Proton/DXVK.
# Útil para contornar crashes (ex.: NVIDIA + HDR/Wayland) em launchers como Heroic/Steam.

export PROTON_ENABLE_WAYLAND=0
export PROTON_ENABLE_HDR=0
export DXVK_HDR=0

exec "$@"

#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# Autor: rag
#
# O que é:
# - Script que gera uma configuração temporária do `hyprlock` com base no ambiente atual.
# - Ajusta campos/labels para o monitor interno (eDP-1) e, se existir, um monitor externo (DP-*).
#
# Por quê:
# - Evita manter múltiplos arquivos de config; adapta automaticamente ao setup de monitores.
# - Reaproveita o wallpaper configurado no hyprpaper.
#
# Como:
# - Detecta monitor DP via `hyprctl monitors -j | jq`.
# - Lê o wallpaper do `~/.config/hypr/hyprpaper.conf`.
# - Escreve `hyprlock.conf` em `/tmp` e chama `hyprlock -c` se ainda não estiver rodando.
#
# Riscos:
# - Depende de `hyprctl`, `jq`, `hyprpaper` e `hyprlock`.
# - Se o arquivo do hyprpaper mudar de formato, a extração de wallpaper pode falhar.
# =============================================================================

# Caminho do arquivo de configuração gerado dinamicamente
TMP_CONFIG="/tmp/hyprlock.conf"

# Encontra o monitor DP conectado (se existir)
DP_MONITOR=$(hyprctl monitors -j | jq -r '.[] | select(.name | startswith("DP-")) | .name' | head -n 1)

# Obtém o wallpaper a partir da config atual do hyprpaper
WALLPAPER=$(grep 'wallpaper = ' ~/.config/hypr/hyprpaper.conf | sed 's/wallpaper = ,//' | tr -d '\n')

# --- Gera o arquivo de configuração ---
cat >"$TMP_CONFIG" <<EOF
background {
    path = $WALLPAPER
    blur_passes = 3
    contrast = 0.8916
    brightness = 0.8172
    vibrancy = 0.1696
    vibrancy_darkness = 0.0
}

general {
    fail_timeout = 1000
}

input-field {
    monitor = eDP-1
    size = 500, 120
    outline_thickness = 2
    dots_size = 0.2
    dots_spacing = 0.2
    dots_center = true
    outer_color = rgba(0, 0, 0, 0)
    inner_color = rgba(0, 0, 0, 0.5)
    font_color = rgb(200, 200, 200)
    fade_on_empty = false
    capslock_color = -1
    placeholder_text = <i><span foreground="##e6e9ef">Password</span></i>
    fail_text = <i>\$FAIL <b>(\$ATTEMPTS)</b></i>
    hide_input = false
    position = 0, -120
    halign = center
    valign = center
}
label {
    monitor = eDP-1
    text = cmd[update:1000] echo "<span>\$(date '+%A, %d %B')</span>"
    color = rgba(255, 255, 255, 0.8)
    font_size = 30
    font_family = Monocraft
    position = 0, -400
    halign = center
    valign = top
}
label {
    monitor = eDP-1
    text = cmd[update:1000] echo "<span>\$(date '+%H:%M:%S')</span>"
    color = rgba(255, 255, 255, 0.8)
    font_size = 240
    font_family = Monocraft
    position = 0, -400
    halign = center
    valign = top
}
label {
    monitor = eDP-1
    text = \$LAYOUT
    color = rgba(255, 255, 255, 0.9)
    font_size = 20
    font_family = Monocraft
    position = 0, -230
    halign = center
    valign = center
}
EOF

# Anexa configurações para o monitor DP-* (se existir)
if [[ -n "$DP_MONITOR" ]]; then
	cat >>"$TMP_CONFIG" <<EOF

# Config dinâmica para $DP_MONITOR (monitor externo)
input-field {
    monitor = $DP_MONITOR
    size = 250, 60
    outline_thickness = 2
    dots_size = 0.2
    dots_spacing = 0.2
    dots_center = true
    outer_color = rgba(0, 0, 0, 0)
    inner_color = rgba(0, 0, 0, 0.5)
    font_color = rgb(200, 200, 200)
    fade_on_empty = false
    capslock_color = -1
    placeholder_text = <i><span foreground="##e6e9ef">Password</span></i>
    fail_text = <i>\$FAIL <b>(\$ATTEMPTS)</b></i>
    hide_input = false
    position = 0, -120
    halign = center
    valign = center
}
label {
    monitor = $DP_MONITOR
    text = cmd[update:1000] echo "<span>\$(date '+%A, %d %B')</span>"
    color = rgba(255, 255, 255, 0.8)
    font_size = 15
    font_family = Monocraft
    position = 0, -400
    halign = center
    valign = top
}
label {
    monitor = $DP_MONITOR
    text = cmd[update:1000] echo "<span>\$(date '+%H:%M:%S')</span>"
    color = rgba(255, 255, 255, 0.8)
    font_size = 120
    font_family = Monocraft
    position = 0, -400
    halign = center
    valign = top
}
label {
    monitor = $DP_MONITOR
    text = \$LAYOUT
    color = rgba(255, 255, 255, 0.9)
    font_size = 10
    font_family = Monocraft
    position = 0, -175
    halign = center
    valign = center
}
EOF
fi

if ! pgrep -x hyprlock >/dev/null; then
	hyprlock -c "$TMP_CONFIG"
fi

# Remove o arquivo temporário ao final
rm -f "$TMP_CONFIG"

{
  "mcpServers": {
    "kryonix-brain": {
      "command": "ssh",
      "args": [
        "glacier",
        "cd /etc/kryonix && uv run --project packages/kryonix-brain-lightrag kg-server"
      ]
    },
    "mcp-nixos": {
      "command": "uv",
      "args": [
        "tool",
        "run",
        "mcp-nixos",
        "--stdio"
      ]
    },
    "vault-readonly": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/etc/kryonix",
        "/ABSOLUTE/PATH/TO/kryonix-vault"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github",
        "--stdio"
      ]
    }
  }
}
